import {MockInstance, vi} from 'vitest'
import { config } from '@vue/test-utils'
import { initApi } from '../services/api'

declare global {
  var vi: any // Or import { vi } from 'vitest' and use its specific type
  var navigateTo: MockInstance
  var definePageMeta: MockInstance
  var defineNuxtRouteMiddleware: any
  var useRuntimeConfig: MockInstance
}

globalThis.vi = vi
globalThis.navigateTo = vi.fn()
globalThis.definePageMeta = vi.fn()
globalThis.defineNuxtRouteMiddleware = vi.fn(() => ({}))

// Mock useRuntimeConfig
globalThis.useRuntimeConfig = vi.fn(() => ({
  public: {
    apiBase: 'http://localhost:8000'
  }
}))

// Initialize API with test base URL
initApi('http://localhost:8000')

// Mock document.cookie for API client
Object.defineProperty(document, 'cookie', {
  writable: true,
  value: 'access_token=mock-token'
})

// Mock fetch API with default response that can be overridden
export const mockFetch = vi.fn(() =>
  Promise.resolve(new Response(JSON.stringify({
    items: [],
    pagination: {
      current_page: 1,
      total_pages: 1,
      total_items: 0,
      items_per_page: 25
    }
  }), {
    status: 200,
    statusText: 'OK',
    headers: {
      'Content-Type': 'application/json'
    },
    ok: true
  })

// @ts-ignore
global.fetch = mockFetch

// Configure Vue Test Utils
config.global.stubs = {
  'NuxtLink': true,
  'NuxtRouteAnnouncer': true,
  'NuxtPage': true,
  'ClientOnly': {
    template: '<div><slot /></div>',
    props: []
  }
}

// Mock Vue components for testing
config.global.mocks = {
  NuxtRouteAnnouncer: {
    template: '<nuxt-route-announcer-stub></nuxt-route-announcer-stub>'
  },
  NuxtPage: {
    template: '<nuxt-page-stub></nuxt-page-stub>'
  }
}
