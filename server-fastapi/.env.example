ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-this-in-production
# When the backend runs in Docker and Ollama runs on the host, use host.docker.internal.
# For a remote Ollama server, replace this with your server URL.
OLLAMA_API_URL=http://host.docker.internal:11434
DATABASE_URL=sqlite:///./kitchen.db
OLLAMA_API_KEY=
DEFAULT_OLLAMA_MODEL=qwen3:8b
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8001,http://127.0.0.1:8001,https://freemock.top:18001,https://freemock.top:18000
